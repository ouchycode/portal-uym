{
  "expo": {
    "name": "Portal UYM",
    "slug": "portal-uym",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-uym.png",
    "scheme": "portaluym",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A4C8B",
        "foregroundImage": "./assets/images/logo-uym.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.uym.portal"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-uym.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#1A4C8B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
