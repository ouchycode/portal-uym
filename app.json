{
  "expo": {
    "name": "Portal UYM",
    "slug": "portal-uym",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-uym.png",
    "scheme": "portaluym",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A4C8B",
        "foregroundImage": "./assets/images/logo-uym.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.uym.portal"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-uym.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#1A4C8B"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cfd4f0dd-9f2c-4a63-91cb-fff8a834b1e0"
      }
    }
  }
}
